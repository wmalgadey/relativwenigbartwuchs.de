{% macro renderNavItemPage(entry) -%}
  {% if entry.url === page.url -%}
  <li class="active" aria-current="page">
    <strong>{{ entry.title }}</strong>
  </li>
  {%- else -%}
  <li>
    <a href="{{ entry.url }}">{{ entry.title }}</a>
  </li>
  {%- endif %}
{%- endmacro %}

{% macro renderNavItem(entry) -%}
  {% set entryUrl = entry.url or (entry.path + (entry.title | slugify)) %}
  {% if entryUrl === page.url -%}
  <li class="active" aria-current="page">
    <strong>{{ entry.label or entry.title }}</strong>
  </li>
  {%- else -%}
  <li>
    <a href="{{ entryUrl }}">{{ entry.label or entry.title }}</a>
  </li>
  {%- endif %}
{%- endmacro %}

