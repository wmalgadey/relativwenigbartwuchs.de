{% extends "layouts/main.njk" %}

{% block content %}

  <section class="content">

    <header>
      <h1 class="title">{{ title }}</h1>

      {% if dateCreated %}
        <p class="subtitle">
          Zuletzt bearbeitet am
          <time datetime="{{ dateCreated | dateymd }}">{{ dateCreated | datefriendly }}</time>
        </p>
      {% endif %}
    </header>

    <div class="columns is-centered">
      <div class="column is-three-fifths">
        {{ content | safe }}
      </div>
    </div>

  </section>

{% endblock %}
