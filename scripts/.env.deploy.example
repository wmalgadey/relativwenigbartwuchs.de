# Deployment-Konfiguration für lokale Tests
# Kopieren nach .env.deploy (liegt in .gitignore) und Werte eintragen:
#   cp scripts/.env.deploy.example .env.deploy

DEPLOY_HOST=example.com
DEPLOY_USER=myuser
SSH_PORT=22

CPANEL_USER=myuser
CPANEL_TOKEN=my-cpanel-api-token

# Optionale Overrides (Defaults aus .gitlab-ci.yml)
# SITE_DIR=sites/relativwenigbartwuchs.de
