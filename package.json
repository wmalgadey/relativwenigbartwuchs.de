{
  "name": "relativwenigbartwuchs.de",
  "version": "1.0.0",
  "description": "my personal weblog",
  "type": "module",
  "main": ".eleventy.js",
  "scripts": {
    "start": "ELEVENTY_ENV=development NODE_NO_WARNINGS=1 npx eleventy --serve",
    "production": "npm run clean && NODE_NO_WARNINGS=1 npx eleventy && npx pagefind --site _site",
    "debug": "DEBUG=Eleventy* npx @11ty/eleventy",
    "clean": "rm -rf _site"
  },
  "author": "Wolfgang Malgadey",
  "license": "ISC",
  "overrides": {
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-fetch": "^5.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@pagefind/component-ui": "^1.5.2",
    "bulma": "^1.0.4",
    "cssnano": "^7.1.4",
    "cssom": "^0.5.0",
    "eleventy-plugin-gen-favicons": "^1.1.2",
    "esbuild": "^0.28.0",
    "extend": "^3.0.2",
    "glob": "^13.0.6",
    "html-minifier": "^4.0.0",
    "inline-source": "^8.0.2",
    "linkedom": "^0.18.12",
    "markdown-it": "^14.0.0",
    "markdown-it-attrs": "^4.1.6",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-regexp": "^0.4.0",
    "pagefind": "^1.5.2",
    "postcss": "^8.4.21",
    "postcss-advanced-variables": "^5.0.0",
    "postcss-nested": "^7.0.2",
    "sanitize-filename": "^1.6.3",
    "sass": "^1.99.0",
    "uhyphen": "^0.2.0"
  },
  "optionalDevDependencies": {
    "@img/sharp-libvips-darwin-x64": "^1.0.4"
  }
}
