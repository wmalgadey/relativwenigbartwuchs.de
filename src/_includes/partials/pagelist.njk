{% if pagelist %}
  <section class="content">
    <div class="columns is-multiline">

      {%- for post in pagelist -%}
        <div class="column post is-4">
          <article class="columns is-multiline">

            <div class="column is-12 post-img">
              {% if post.data.coverImage %}
                <figure style="height:300px">
                  {% coverImageUri post.data.coverImage,
                  post.url,
                  post.data.title %}
                </figure>
              {% else %}
                <div style="height:300px">&nbsp;</div>
              {% endif %}
            </div>

            <div class="column is-12 featured-content ">
              <h3 class="title">
                <a href="{{ post.url }}">{{ post.data.title }}</a>
              </h3>

              {% if post.data.date %}
                <p class="subtitle">
                  <time datetime="{{ post.data.date | dateymd }}">{{ post.data.date | datefriendly }}</time>
                </p>
              {% endif %}

              <p class="post-excerpt">{% excerpt post %}</p>

              {% if post.date %}
                <p class="time">
                  <time datetime="{{ post.date | dateymd }}">{{ post.date | datefriendly }}</time>
                </p>
              {% endif %}
            </div>
          </article>
        </div>
      {%- endfor -%}
    </div>
  </section>
{% endif %}

{% if pagination.href.previous or pagination.href.next %}
  <nav class="level">
    <div class="level-left">
      {% if pagination.href.previous %}
        <p class="level-item">
          <a href="{{ pagination.href.previous }}">Neuere Beiträge</a>
        </p>
      {% endif %}
    </div>

    <div class="level-right">
      {% if pagination.href.next %}
        <p class="level-item">
          <a href="{{ pagination.href.next }}">Ältere Beiträge</a>
        </p>
      {% endif %}
    </div>

  </nav>
{% endif %}