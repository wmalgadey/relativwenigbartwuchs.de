{% if pagelist -%}
  <ul class="columns is-multiline ml-0">
    {%- for post in pagelist -%}
      <li class="column is-4 pl-0">
        {%- coverimage post.data.coverImage, post.data.title, page=post -%}
        <h3 class="title">
          <a href="{{ post.url }}">{{ post.data.title }}</a>
        </h3>
        {%- if post.data.date -%}
          <p class="subtitle">
            <time datetime="{{ post.data.date | dateymd }}">{{ post.data.date | datefriendly }}</time>
          </p>
        {%- endif -%}
        <p>{% excerpt post %}</p>
        {%- if post.date -%}
          <p class="time">
            <time datetime="{{ post.date | dateymd }}">{{ post.date | datefriendly }}</time>
          </p>
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
{%- endif %}